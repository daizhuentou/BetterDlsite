//<!CDATA[

(function($){
    "use strict";
    var loginchecked = document.getCookie('loginchecked');
    var sid = document.getCookie('iom_' + dlsite.getLang());

    if (loginchecked === '1' || loginchecked === '3'){
      $.each([
        {
          url:'https://www.dlsite.com/maniax/left/favorite/content/=/type/followlist',
          html_key: 'FOLLOWLIST_CACHE_HTML',
          expire_key: 'FOLLOWLIST_CACHE_EXPIRE',
          $target: $('#left_favorite_followlist'),
          $container: $('#left_favorite_fl_module'),
          sid: sid,
          lang: 'jp'
        },
        {
          url:'https://www.dlsite.com/maniax/left/favorite/content/=/type/searchwords',
          html_key: 'SEARCHWORDS_CACHE_HTML',
          expire_key: 'SEARCHWORDS_CACHE_EXPIRE',
          $target: $('#left_favorite_searchwords'),
          $container: $('#left_favorite_sw_module'),
          sid: sid,
          lang: 'jp'
        }
      ], function(i, options){
          var cache = _.clone($.mygenre_cache, true);
          cache.init(options);
          cache.$target.bind('loaded', function(e){
            if ($(e.target).find('.list_content').length) {
              cache.$container.show();
              cache.initializeSlideMenus($(e.target).find('__slide_menu'));
            }
          });
          cache.get();
      });
    }
})(jQuery);

//]]>
</script>
  
